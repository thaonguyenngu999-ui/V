   if (!DomWindow())
     return 0;
   return static_cast<unsigned>(GetColorDepth());
@@ -51,6 +99,15 @@ unsigned Screen::colorDepth() const {
 }
 
 unsigned Screen::pixelDepth() const {
+  // ChromiumSoncuto: Return spoofed pixelDepth
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
