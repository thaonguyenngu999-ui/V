 #include "third_party/blink/renderer/core/page/chrome_client.h"
 
+// ChromiumSoncuto: Include fingerprint controller
+#include "chromiumsoncuto/fingerprint_controller/fingerprint_config.h"
+
 namespace blink {
 
 Screen::Screen(LocalDOMWindow* window, int64_t display_id)
@@ -16,6 +19,15 @@ Screen::Screen(LocalDOMWindow* window, int64_t display_id)
 Screen::~Screen() = default;
 
 int Screen::width() const {
+  // ChromiumSoncuto: Return spoofed width
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (controller->IsInitialized()) {
+    const auto* profile = controller->GetProfile();
+    if (profile) {
+      return profile->screen.width;
+    }
+  }
+
   if (!DomWindow())
     return 0;
   return GetRect().width();
