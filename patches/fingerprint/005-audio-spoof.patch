From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ChromiumSoncuto <chromiumsoncuto@example.com>
Date: Mon, 1 Jan 2024 00:00:00 +0700
Subject: [PATCH 005/006] Audio fingerprint noise injection

Apply subtle, consistent noise to AudioContext operations to prevent
audio fingerprinting while maintaining audio quality.

---
 third_party/blink/renderer/modules/webaudio/audio_context.cc | 80 +++++++++++++
 third_party/blink/renderer/modules/webaudio/analyser_node.cc | 60 ++++++++++
 third_party/blink/renderer/modules/webaudio/oscillator_node.cc | 40 ++++++
 third_party/blink/renderer/modules/webaudio/offline_audio_context.cc | 50 ++++++++
 4 files changed, 230 insertions(+)

diff --git a/third_party/blink/renderer/modules/webaudio/audio_context.cc b/third_party/blink/renderer/modules/webaudio/audio_context.cc
index 1234567890..abcdefghij 100644
--- a/third_party/blink/renderer/modules/webaudio/audio_context.cc
+++ b/third_party/blink/renderer/modules/webaudio/audio_context.cc
@@ -10,6 +10,10 @@
 #include "third_party/blink/renderer/modules/webaudio/audio_destination_node.h"
 #include "third_party/blink/renderer/platform/audio/audio_utilities.h"
 
+// ChromiumSoncuto: Include audio spoof
+#include "chromiumsoncuto/fingerprint_controller/fingerprint_config.h"
+#include "chromiumsoncuto/fingerprint_controller/audio_spoof.h"
+
 namespace blink {
 
 AudioContext* AudioContext::Create(Document& document,
@@ -20,6 +24,25 @@ AudioContext* AudioContext::Create(Document& document,
 }
 
 float AudioContext::sampleRate() const {
+  // ChromiumSoncuto: Return spoofed sample rate
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (controller->IsInitialized()) {
+    const auto* profile = controller->GetProfile();
+    if (profile && profile->audio.enabled) {
+      return profile->audio.sample_rate;
+    }
+  }
+
   return destination()->context()->sampleRate();
 }

@@ -30,6 +53,15 @@ double AudioContext::currentTime() const {
 }
 
 double AudioContext::baseLatency() const {
+  // ChromiumSoncuto: Return spoofed base latency with slight noise
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (controller->IsInitialized()) {
+    const auto* profile = controller->GetProfile();
+    if (profile && profile->audio.enabled) {
+      return profile->audio.base_latency;
+    }
+  }
+
   return GetOutputLatency(kBaseLatency);
 }
 
@@ -40,6 +72,15 @@ double AudioContext::outputLatency() const {
 }
 
 unsigned AudioContext::channelCount() const {
+  // ChromiumSoncuto: Return spoofed channel count
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (controller->IsInitialized()) {
+    const auto* profile = controller->GetProfile();
+    if (profile && profile->audio.enabled) {
+      return profile->audio.destination_channel_count;
+    }
+  }
+
   return destination()->channelCount();
 }
 
