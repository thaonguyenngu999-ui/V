@@ -45,6 +67,31 @@ void BaseRenderingContext2D::putImageData(ImageData* image_data,
     ExceptionState& exception_state) {
   putImageData(image_data, dx, dy, 0, 0, image_data->width(), image_data->height(), exception_state);
 }
+
+// ChromiumSoncuto: Helper function to generate consistent noise
+namespace {
+
+void ApplyNoiseToPixelData(uint8_t* data, int width, int height,
+                           uint64_t seed, double intensity) {
+  // Xorshift128+ PRNG for deterministic noise
+  uint64_t state0 = seed;
+  uint64_t state1 = seed ^ 0x5DEECE66DULL;
+  if (state0 == 0) state0 = 1;
+  if (state1 == 0) state1 = 1;
+  
+  for (int i = 0; i < width * height * 4; i += 4) {
+    // Generate noise for RGB channels only, preserve alpha
+    for (int c = 0; c < 3; c++) {
+      uint64_t s1 = state0;
+      const uint64_t s0 = state1;
+      state0 = s0;
+      s1 ^= s1 << 23;
+      state1 = s1 ^ s0 ^ (s1 >> 17) ^ (s0 >> 26);
+      
+      double noise = ((state1 + s0) >> 11) * (1.0 / (1ULL << 53));
+      noise = (noise * 2.0 - 1.0) * intensity * 255.0;
+      
+      int value = static_cast<int>(data[i + c]) + static_cast<int>(noise);
+      data[i + c] = static_cast<uint8_t>(std::clamp(value, 0, 255));
+    }
+  }
+}
+
+}  // namespace
 
 }  // namespace blink

