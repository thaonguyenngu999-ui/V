 namespace devtools_instrumentation {
 
@@ -20,6 +23,12 @@ void ApplyNetworkRequestOverrides(FrameTreeNode* frame_tree_node,
 }
 
 bool IsWebDriverActiveForFrame(RenderFrameHostImpl* frame_host) {
+  // ChromiumSoncuto: Always return false to prevent detection
+  // This prevents the browser from setting automation-related flags
+  // that can be detected by anti-bot systems
+  return false;
+
+  // Original implementation (disabled)
   if (!frame_host)
     return false;
   
