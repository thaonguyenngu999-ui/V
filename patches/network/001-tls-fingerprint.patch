From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ChromiumSoncuto <chromiumsoncuto@example.com>
Date: Mon, 1 Jan 2024 00:00:00 +0700
Subject: [PATCH 001/001] TLS fingerprint normalization

Normalize TLS fingerprint to match standard Chrome browser.

This patch ensures the TLS ClientHello matches a real Chrome browser
to avoid detection via JA3 or similar TLS fingerprinting methods.

---
 net/socket/ssl_client_socket_impl.cc | 100 ++++++++++++++++++++++++++++
 net/ssl/ssl_config.cc                |  50 ++++++++++++++
 net/ssl/ssl_config.h                 |  15 +++++
 3 files changed, 165 insertions(+)

diff --git a/net/socket/ssl_client_socket_impl.cc b/net/socket/ssl_client_socket_impl.cc
index 1234567890..abcdefghij 100644
--- a/net/socket/ssl_client_socket_impl.cc
+++ b/net/socket/ssl_client_socket_impl.cc
@@ -25,6 +25,9 @@
 #include "third_party/boringssl/src/include/openssl/ssl.h"
 #include "third_party/boringssl/src/include/openssl/err.h"
 
+// ChromiumSoncuto: TLS fingerprint configuration
+#include "chromiumsoncuto/fingerprint_controller/fingerprint_config.h"
+
 namespace net {
 
 namespace {
@@ -50,6 +53,60 @@ const uint16_t kDefaultCipherSuites[] = {
     0x1302,  // TLS_AES_256_GCM_SHA384
     0x1303,  // TLS_CHACHA20_POLY1305_SHA256
     0xc02c,  // TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384
+    0xc02b,  // TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
+    0xc030,  // TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
+    0xc02f,  // TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
+    0xcca9,  // TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256
+    0xcca8,  // TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256
+    0xc014,  // TLS_ECDHE_RSA_WITH_AES_256_CBC_SHA
+    0xc013,  // TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA
+    0x009d,  // TLS_RSA_WITH_AES_256_GCM_SHA384
+    0x009c,  // TLS_RSA_WITH_AES_128_GCM_SHA256
+};
+
+// Chrome 120 cipher suite order (for JA3 fingerprint matching)
+const uint16_t kChrome120CipherSuites[] = {
+    0x1301,  // TLS_AES_128_GCM_SHA256
+    0x1302,  // TLS_AES_256_GCM_SHA384
+    0x1303,  // TLS_CHACHA20_POLY1305_SHA256
+    0xc02b,  // TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
+    0xc02f,  // TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
+    0xc02c,  // TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384
+    0xc030,  // TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
+    0xcca9,  // TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256
+    0xcca8,  // TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256
+    0xc013,  // TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA
+    0xc014,  // TLS_ECDHE_RSA_WITH_AES_256_CBC_SHA
+    0x009c,  // TLS_RSA_WITH_AES_128_GCM_SHA256
+    0x009d,  // TLS_RSA_WITH_AES_256_GCM_SHA384
+    0x002f,  // TLS_RSA_WITH_AES_128_CBC_SHA
+    0x0035,  // TLS_RSA_WITH_AES_256_CBC_SHA
+};
+
+// Chrome 120 extension order
+const uint16_t kChrome120Extensions[] = {
+    0x0000,  // server_name
+    0x0017,  // extended_master_secret
+    0xff01,  // renegotiation_info
+    0x000a,  // supported_groups
+    0x000b,  // ec_point_formats
+    0x0023,  // session_ticket
+    0x0010,  // application_layer_protocol_negotiation
+    0x0005,  // status_request
+    0x000d,  // signature_algorithms
+    0x0012,  // signed_certificate_timestamp
+    0x002b,  // supported_versions
+    0x002d,  // psk_key_exchange_modes
+    0x0033,  // key_share
+    0x001b,  // compress_certificate
+    0x0015,  // padding
 };
 
 }  // namespace
@@ -100,6 +157,35 @@ int SSLClientSocketImpl::Init() {
   SSL_CTX* ssl_ctx = GetSSLContext();
   ssl_.reset(SSL_new(ssl_ctx));
 
+  // ChromiumSoncuto: Configure TLS to match real Chrome
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (controller->IsInitialized()) {
+    // Use Chrome 120 cipher suite order
+    if (!SSL_set_cipher_list(ssl_.get(), GetChrome120CipherString())) {
+      LOG(WARNING) << "Failed to set Chrome 120 cipher list";
+    }
+    
+    // Set supported groups (curves) in Chrome order
+    static const int kChrome120Curves[] = {
+        NID_X25519,
+        NID_X9_62_prime256v1,  // P-256
+        NID_secp384r1,         // P-384
+    };
+    SSL_set1_curves(ssl_.get(), kChrome120Curves, 
+                    sizeof(kChrome120Curves) / sizeof(kChrome120Curves[0]));
+    
+    // Enable GREASE for randomization (Chrome does this)
+    SSL_set_grease_enabled(ssl_.get(), 1);
+    
+    // Set ALPN protocols in Chrome order
+    static const uint8_t kALPNProtos[] = {
+        2, 'h', '2',
+        8, 'h', 't', 't', 'p', '/', '1', '.', '1',
+    };
+    SSL_set_alpn_protos(ssl_.get(), kALPNProtos, sizeof(kALPNProtos));
+  }
+
   if (!ssl_) {
     return ERR_UNEXPECTED;
   }
@@ -120,6 +206,18 @@ int SSLClientSocketImpl::Init() {
   return OK;
 }
 
+// ChromiumSoncuto: Get Chrome 120 compatible cipher string
+const char* SSLClientSocketImpl::GetChrome120CipherString() {
+  // Cipher string that produces Chrome 120-like JA3 fingerprint
+  return "TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:"
+         "TLS_CHACHA20_POLY1305_SHA256:"
+         "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:"
+         "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:"
+         "ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:"
+         "ECDHE-RSA-AES128-SHA:ECDHE-RSA-AES256-SHA:"
+         "AES128-GCM-SHA256:AES256-GCM-SHA384:AES128-SHA:AES256-SHA";
+}
+
 }  // namespace net

diff --git a/net/ssl/ssl_config.cc b/net/ssl/ssl_config.cc
index abcdefghij..1234567890 100644
--- a/net/ssl/ssl_config.cc
+++ b/net/ssl/ssl_config.cc
@@ -5,6 +5,9 @@
 #include "net/ssl/ssl_config.h"
 #include "net/cert/cert_verifier.h"
 
+// ChromiumSoncuto: TLS fingerprint configuration
+#include "chromiumsoncuto/fingerprint_controller/fingerprint_config.h"
+
 namespace net {
 
 SSLConfig::SSLConfig() = default;
@@ -15,6 +18,35 @@ SSLConfig::SSLConfig(const SSLConfig& other) = default;
 
 SSLConfig::~SSLConfig() = default;
 
+void SSLConfig::ApplyChromiumSoncutoConfig() {
+  // ChromiumSoncuto: Apply TLS settings for fingerprint consistency
+  auto* controller = &chromiumsoncuto::FingerprintController::GetInstance();
+  if (!controller->IsInitialized()) {
+    return;
+  }
+  
+  // Enable TLS 1.3
+  version_max = SSL_PROTOCOL_VERSION_TLS1_3;
+  version_min = SSL_PROTOCOL_VERSION_TLS1_2;
+  
+  // Disable features that can leak information
+  disable_sha1_server_signatures = true;
+  
+  // Enable session tickets (Chrome default)
+  enable_session_resumption = true;
+  
+  // OCSP stapling (Chrome default)
+  ocsp_stapling_enabled = true;
+  
+  // Certificate transparency (Chrome default)
+  ct_policy_compliance_required = true;
+  
+  // Enable ALPN (Application-Layer Protocol Negotiation)
+  alpn_protos = {NextProto::kProtoHTTP2, NextProto::kProtoHTTP11};
+  
+  // Enable encrypted client hello if available
+  ech_enabled = true;
+}
+
 }  // namespace net

diff --git a/net/ssl/ssl_config.h b/net/ssl/ssl_config.h
index 1234567890..abcdefghij 100644
--- a/net/ssl/ssl_config.h
+++ b/net/ssl/ssl_config.h
@@ -80,6 +80,21 @@ struct NET_EXPORT SSLConfig {
   // ECH (Encrypted Client Hello) configuration
   bool ech_enabled = true;
   std::vector<uint8_t> ech_config_list;
+  
+  // ChromiumSoncuto: TLS fingerprint configuration
+  // Apply settings to match Chrome browser TLS fingerprint
+  void ApplyChromiumSoncutoConfig();
+  
+  // Use Chrome 120 compatible cipher suite ordering
+  bool use_chrome_cipher_order = true;
+  
+  // Enable GREASE (Generate Random Extensions And Sustain Extensibility)
+  bool grease_enabled = true;
+  
+  // Permute extensions order (Chrome randomizes some extension order)
+  bool permute_extensions = false;
+  
+  // Compress certificates (Chrome supports this)
+  bool compress_certificates = true;
 };
 
 }  // namespace net
-- 
